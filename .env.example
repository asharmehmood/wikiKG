# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and adjust values for your environment
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────
# Ollama connection
# ──────────────────────────────────────────────
# Where the backend container can reach Ollama.
# Choose the value that matches your setup:
#
#   Docker Desktop (Mac / Windows):  http://host.docker.internal:11434
#   Linux — Ollama on the host:      http://host.docker.internal:11434
#                                    (requires `extra_hosts: host-gateway` in compose)
#                                    Start Ollama with: OLLAMA_HOST=0.0.0.0:11434 ollama serve
#   Ollama as a compose service:     http://ollama:11434
#
OLLAMA_HOST=http://host.docker.internal:11434

# ──────────────────────────────────────────────
# Models
# ──────────────────────────────────────────────
# Generation model — must be pulled on the Ollama instance before first use.
#   ollama pull llama3:8b
# Other options: llama3.1:8b, mistral:7b, gemma3:4b
GEN_MODEL=llama3:8b

# Embedding model — must also be pulled.
#   ollama pull mxbai-embed-large
# Other options: nomic-embed-text
EMBED_MODEL=mxbai-embed-large

# ──────────────────────────────────────────────
# Qdrant connection
# ──────────────────────────────────────────────
# When using docker compose, leave these as-is.
# For an external Qdrant instance, set QDRANT_HOST to its hostname/IP.
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ──────────────────────────────────────────────
# Chunking parameters (DESIGN.md §4)
# ──────────────────────────────────────────────
# Maximum characters per chunk sent to the embedder.
CHUNK_SIZE=1500
# Overlap between consecutive chunks (improves retrieval context continuity).
CHUNK_OVERLAP=200

# ──────────────────────────────────────────────
# Retrieval
# ──────────────────────────────────────────────
# Number of chunks retrieved per query.
TOP_K=4

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Host port (informational — used in entrypoint banner only)
# ──────────────────────────────────────────────
# Must match the host-side port in docker-compose.yml (default: 9000:8000).
HOST_PORT=9000
