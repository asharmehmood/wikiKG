# ──────────────────────────────────────────────
# Ollama connection
# ──────────────────────────────────────────────
# Docker Desktop / Mac / Windows: use host.docker.internal
# Linux host Ollama:              use http://172.17.0.1:11434
# Compose ollama service:         use http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Models — must already be pulled on the Ollama instance
# ollama pull llama3.1:8b
# ollama pull mxbai-embed-large
GEN_MODEL=llama3.1:8b
EMBED_MODEL=mxbai-embed-large

# ──────────────────────────────────────────────
# Qdrant connection
# ──────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ──────────────────────────────────────────────
# Chunking parameters (DESIGN.md §4)
# ──────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# ──────────────────────────────────────────────
# Retrieval
# ──────────────────────────────────────────────
TOP_K=4

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
LOG_LEVEL=INFO
